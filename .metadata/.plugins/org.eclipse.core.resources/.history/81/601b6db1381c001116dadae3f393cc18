package com.dsa.pattern;

public class two_pointers {

	/**
	 * Used when two indices move through a structure
	 * prompt:write a program for step by step understanding how to use this pattern wherever there is need
	 * This approach is for sorted array.
	 * For unsorted array sort array first and use this approach
	 * */
	public static void findPair(int[] arr, int target) {

        int left = 0;                  // pointer starting from beginning
        int right = arr.length - 1;    // pointer starting from end
        int step = 1;

        while (left < right) {

            int sum = arr[left] + arr[right];

            System.out.println("Step " + step++);
            System.out.println("Left Pointer Index: " + left + " Value: " + arr[left]);
            System.out.println("Right Pointer Index: " + right + " Value: " + arr[right]);
            System.out.println("Current Sum: " + sum);

            if (sum == target) {
                System.out.println("Pair Found: " + arr[left] + " + " + arr[right] + " = " + target);
                return;
            }
            else if (sum < target) {
                System.out.println("Sum is smaller than target → Move LEFT pointer forward\n");
                left++;
            }
            else {
                System.out.println("Sum is greater than target → Move RIGHT pointer backward\n");
                right--;
            }
        }

        System.out.println("No pair found.");
    }

    public static void main(String[] args) {

        int[] arr = {1, 2, 3, 4, 6, 8, 9};
        int target = 10;

        System.out.println("Array: ");
        for (int num : arr) {
            System.out.print(num + " ");
        }

        System.out.println("\nTarget: " + target);
        System.out.println("\n--- Two Pointer Execution ---\n");

        findPair(arr, target);
    }
	
}
