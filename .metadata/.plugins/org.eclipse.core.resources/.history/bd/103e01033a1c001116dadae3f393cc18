package com.dsa.pattern;

public class TwoPointers {

	/**
	 * Demonstrates the <b>Two Pointers Pattern</b>.
	 *
	 * <p>
	 * This technique is used when two indices move through a data structure
	 * (typically an array) from opposite directions.
	 * </p>
	 *
	 * <h2>When to Use</h2>
	 * <ul>
	 *   <li>Array is sorted</li>
	 *   <li>Finding a pair with a specific condition (ex: target sum)</li>
	 *   <li>Optimizing nested loops from O(n²) to O(n)</li>
	 * </ul>
	 *
	 * <h2>Important</h2>
	 * This approach requires a <b>sorted array</b>.  
	 * If the array is not sorted, sort it first before applying this technique.
	 *
	 * <h2>Example Implementation</h2>
	 *
	 * <pre>{@code
	 * package com.dsa.pattern;
	 *
	 * public class TwoPointersExample {
	 *
	 *     public static void findPair(int[] arr, int target) {
	 *
	 *         int left = 0;
	 *         int right = arr.length - 1;
	 *         int step = 1;
	 *
	 *         while (left < right) {
	 *
	 *             int sum = arr[left] + arr[right];
	 *
	 *             System.out.println("Step " + step++);
	 *             System.out.println("Left Pointer Index: " + left + " Value: " + arr[left]);
	 *             System.out.println("Right Pointer Index: " + right + " Value: " + arr[right]);
	 *             System.out.println("Current Sum: " + sum);
	 *
	 *             if (sum == target) {
	 *                 System.out.println("Pair Found: " + arr[left] + " + " + arr[right]);
	 *                 return;
	 *             }
	 *             else if (sum < target) {
	 *                 System.out.println("Move LEFT pointer forward");
	 *                 left++;
	 *             }
	 *             else {
	 *                 System.out.println("Move RIGHT pointer backward");
	 *                 right--;
	 *             }
	 *         }
	 *
	 *         System.out.println("No pair found.");
	 *     }
	 *
	 *     public static void main(String[] args) {
	 *
	 *         int[] arr = {1,2,3,4,6,8,9};
	 *         int target = 10;
	 *
	 *         findPair(arr, target);
	 *     }
	 * }
	 * }</pre>
	 *
	 * <h2>Complexity</h2>
	 * <ul>
	 *   <li><b>Time Complexity:</b> O(n)</li>
	 *   <li><b>Space Complexity:</b> O(1)</li>
	 * </ul>
	 */
	public static void findPair(int[] arr, int target) {

        int left = 0;                  // pointer starting from beginning
        int right = arr.length - 1;    // pointer starting from end
        int step = 1;

        while (left < right) {

            int sum = arr[left] + arr[right];

            System.out.println("Step " + step++);
            System.out.println("Left Pointer Index: " + left + " Value: " + arr[left]);
            System.out.println("Right Pointer Index: " + right + " Value: " + arr[right]);
            System.out.println("Current Sum: " + sum);

            if (sum == target) {
                System.out.println("Pair Found: " + arr[left] + " + " + arr[right] + " = " + target);
                return;
            }
            else if (sum < target) {
                System.out.println("Sum is smaller than target → Move LEFT pointer forward\n");
                left++;
            }
            else {
                System.out.println("Sum is greater than target → Move RIGHT pointer backward\n");
                right--;
            }
        }

        System.out.println("No pair found.");
    }

    public static void main(String[] args) {

        int[] arr = {1, 2, 3, 4, 6, 8, 9};
        int target = 10;

        System.out.println("Array: ");
        for (int num : arr) {
            System.out.print(num + " ");
        }

        System.out.println("\nTarget: " + target);
        System.out.println("\n--- Two Pointer Execution ---\n");

        findPair(arr, target);
    }
	
}
